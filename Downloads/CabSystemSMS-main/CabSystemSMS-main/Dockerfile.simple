# Simple Dockerfile for Render deployment
FROM maven:3.9.6-eclipse-temurin-21

# Set working directory
WORKDIR /app

# Copy pom.xml first
COPY pom.xml .

# Copy source code
COPY src ./src

# Build the application
RUN mvn clean package -DskipTests

# Expose port
EXPOSE 8080

# Run the application
CMD ["java", "-jar", "target/*.jar"]